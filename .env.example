# Portainer connection
PORTAINER_HOST=your-portainer-host-or-ip
PORTAINER_PORT=9443
PORTAINER_TOKEN=ptr_xxxxxxxxxxxxxxxxxxxx

# Traefik integration
# TRAEFIK_NETWORK: name of the existing external Docker network shared with Traefik
TRAEFIK_NETWORK=your-traefik-network-name
# TRAEFIK_ENTRYPOINT: Traefik entrypoint name for HTTP traffic
TRAEFIK_ENTRYPOINT=http
# PORTAINER_MCP_HOSTNAME: public hostname routed by Traefik.
# OAuth is enforced by mcp-auth-proxy using Cloudflare Access as an OIDC IdP,
# so this hostname does NOT need to be non-guessable.
PORTAINER_MCP_HOSTNAME=portainer-mcp.your-domain.com

# Cloudflare Access for SaaS (OIDC)
# Create at: Zero Trust -> Access -> Applications -> Add -> SaaS (OIDC).
# Set the Redirect URL in Cloudflare to:
#   https://<PORTAINER_MCP_HOSTNAME>/.auth/oidc/callback
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Example: https://<TEAM>.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<CLIENT_ID>/.well-known/openid-configuration
OIDC_CONFIGURATION_URL=

# Optional: defence-in-depth user allowlist (glob). Leave empty to rely solely on
# the Cloudflare Access policy attached to the SaaS app.
# Example: *@your-domain.com
OIDC_ALLOWED_USERS_GLOB=

# IMAGE_TAG: use 'latest' for the main branch, or a specific tag (e.g. sha-abc1234, v0.7.0)
IMAGE_TAG=latest

# Local build settings (only needed when using the build: override in docker-compose.yml)
PORTAINER_MCP_VERSION=v0.7.0
TARGETARCH=amd64
